# ===== Database =====
# Local dev (SQLite):
DATABASE_URL=file:./db/custom.db
# Vercel production (PostgreSQL — Vercel Postgres / Neon / Supabase):
# DATABASE_URL=postgresql://user:pass@host:5432/dbname?schema=public

# ===== Google Apps Script webhook =====
# doPost(e) pushes leads to Google Sheet + sends customer/owner emails
GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/AKfycbwJX2Ok-SZS24QK8AxZeQLP8wWSytCzfQLYiW8tPKEV35ipHYsqgl2TFN9hVC98i7ou/exec

# ===== SMTP email (PRIMARY delivery path for customer/owner emails) =====
# Gmail App Password (NOT your regular password). Setup:
#   1. Enable 2-Step Verification on nextgendigitalstudio1@gmail.com
#   2. Google Account → Security → App passwords → "Mail" → generate
#   3. Paste the 16-char password below (no spaces).
# If these are empty, email delivery falls back to the Google Apps Script webhook
# (MailApp.sendEmail, 100/day quota — easy to hit).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=nextgendigitalstudio1@gmail.com
SMTP_PASS=
SMTP_FROM=NextGen Digital Studio <nextgendigitalstudio1@gmail.com>

# ===== Admin dashboard =====
NEXT_PUBLIC_ADMIN_PASSWORD=nextgen2025
ADMIN_PASSWORD=nextgen2025

# ===== AI chat provider =====
